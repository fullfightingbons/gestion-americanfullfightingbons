{
  "compatibility_date": "2025-10-08",
  "main": "src/index.ts",
  "name": "gestion-americanfullfightingbons",
  "upload_source_maps": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "routes": [
    {
      "pattern": "gestion.americanfullfightingbons.fr/*",
      "zone_name": "americanfullfightingbons.fr"
    },
    {
      "pattern": "gestion.americanfullfightingbons.fr",
      "zone_name": "americanfullfightingbons.fr"
    }
  ],
  "vars": {
    "HELLOASSO_ORGANIZATION_SLUG": "american-full-fighting-bons-en-chablais"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "678b90d9-5d87-4011-b077-af5a4d0358ee",
      "database_name": "affbc-production",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_STORAGE",
      "bucket_name": "storage"
    },
    {
      "binding": "R2_PDF",
      "bucket_name": "fullfighting-pdf"
    }
  ],
  "observability": {
    "enabled": true
  }
}
