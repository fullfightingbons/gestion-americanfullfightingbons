{
	"name": "gestion-americanfullfightingbons",
	"description": "Cloudflare's native serverless SQL database.",
	"cloudflare": {
		"label": "Worker + D1 Database",
		"products": [
			"Workers",
			"D1"
		],
		"categories": [
			"storage"
		],
		"docs_url": "https://developers.cloudflare.com/d1/",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/6c63cca8-354a-4951-45a0-d58769ac6f00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/aa6158f1-7711-4485-f134-a8c802c0a800/preview",
		"publish": true
	},
	"devDependencies": {
		"esbuild": "^0.24.0",
		"typescript": "5.9.3",
		"wrangler": "4.97.0"
	},
	"scripts": {
		"cf-typegen": "wrangler types",
		"typecheck": "tsc --noEmit",
		"build": "esbuild public/assets/app.js --minify --target=es2019 --legal-comments=none --outfile=public/assets/app.min.js",
		"predev": "npm run build",
		"check": "tsc && npm run build && wrangler deploy --dry-run",
		"deploy": "npm run build && wrangler deploy",
		"dev": "wrangler dev",
		"seedLocalD1": "wrangler d1 migrations apply DB --local"
	},
	"private": true
}
